{
  "name": "@k8o/arte-odyssey",
  "version": "10.1.1",
  "description": "k8o's react ui library",
  "keywords": [
    "components",
    "design-system",
    "k8o",
    "react",
    "typescript",
    "ui"
  ],
  "bugs": {
    "url": "https://github.com/k35o/arte-odyssey/issues"
  },
  "license": "MIT",
  "author": "k8o <kosakanoki@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k35o/arte-odyssey.git"
  },
  "files": [
    "dist/**",
    "docs/**"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./tokens": {
      "import": {
        "types": "./dist/styles/tokens.d.mts",
        "default": "./dist/styles/tokens.mjs"
      }
    },
    "./json-render": {
      "import": {
        "types": "./dist/integrations/json-render/catalog.d.mts",
        "default": "./dist/integrations/json-render/catalog.mjs"
      }
    },
    "./json-render/registry": {
      "import": {
        "types": "./dist/integrations/json-render/registry.d.mts",
        "default": "./dist/integrations/json-render/registry.mjs"
      }
    },
    "./openui": {
      "import": {
        "types": "./dist/integrations/openui/library.d.mts",
        "default": "./dist/integrations/openui/library.mjs"
      }
    },
    "./openui/prompt": {
      "import": {
        "types": "./dist/integrations/openui/prompt.d.mts",
        "default": "./dist/integrations/openui/prompt.mjs"
      }
    },
    "./styles.css": "./dist/styles/index.css"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "vp pack && pnpm build:css",
    "build:css": "mkdir -p dist/styles && cp src/styles/*.css dist/styles/",
    "generate:tokens": "tailwind-token-extractor src/styles/index.css -o src/styles/tokens.generated.ts",
    "check:tokens": "tailwind-token-extractor check src/styles/index.css -o src/styles/tokens.generated.ts",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test:vrt": "VRT=1 vitest run --project=components",
    "test": "vitest run",
    "test:ui": "vitest --ui --coverage",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "vp check",
    "check:write": "vp check --fix"
  },
  "dependencies": {
    "@floating-ui/react": "0.27.19",
    "baseline-status": "1.1.1",
    "clsx": "2.1.1",
    "lucide-react": "1.17.0",
    "motion": "12.40.0",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@json-render/core": "0.19.0",
    "@json-render/react": "0.19.0",
    "@openuidev/lang-core": "0.2.5",
    "@openuidev/react-lang": "0.2.6",
    "@storybook/addon-a11y": "10.4.1",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/addon-mcp": "0.6.0",
    "@storybook/addon-vitest": "10.4.1",
    "@storybook/react-vite": "10.4.1",
    "@tailwindcss/postcss": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser-playwright": "4.1.7",
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/ui": "4.1.7",
    "postcss": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "10.4.1",
    "storybook-addon-mock-date": "3.0.2",
    "storybook-addon-vrt": "0.1.0",
    "tailwind-token-extractor": "0.2.0",
    "tailwindcss": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-react": "2.2.0",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "@json-render/core": ">=0.19.0",
    "@json-render/react": ">=0.19.0",
    "@openuidev/lang-core": ">=0.2.5",
    "@openuidev/react-lang": ">=0.2.6",
    "@types/react": ">=19.0.0",
    "@types/react-dom": ">=19.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "tailwindcss": ">=4.0.0",
    "typescript": ">=6.0.0",
    "zod": ">=4.4.0"
  },
  "peerDependenciesMeta": {
    "@json-render/core": {
      "optional": true
    },
    "@json-render/react": {
      "optional": true
    },
    "@openuidev/lang-core": {
      "optional": true
    },
    "@openuidev/react-lang": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
