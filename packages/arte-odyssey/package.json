{
  "name": "@k8o/arte-odyssey",
  "version": "9.1.0",
  "description": "k8o's react ui library",
  "keywords": [
    "components",
    "design-system",
    "k8o",
    "react",
    "typescript",
    "ui"
  ],
  "bugs": {
    "url": "https://github.com/k35o/arte-odyssey/issues"
  },
  "license": "MIT",
  "author": "k8o <kosakanoki@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k35o/arte-odyssey.git"
  },
  "files": [
    "dist/**",
    "docs/**"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./tokens": {
      "import": {
        "types": "./dist/styles/tokens.d.mts",
        "default": "./dist/styles/tokens.mjs"
      }
    },
    "./styles.css": "./dist/styles/index.css"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "pnpm generate:css && vp pack && pnpm build:css",
    "build:css": "mkdir -p dist/styles && cp src/styles/index.css dist/styles/index.css",
    "generate:css": "node scripts/generate-css.ts",
    "prepare": "pnpm generate:css",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:ui": "vitest --ui --coverage",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "vp check",
    "check:write": "vp check --fix"
  },
  "dependencies": {
    "@floating-ui/react": "0.27.19",
    "baseline-status": "1.1.1",
    "clsx": "2.1.1",
    "lucide-react": "1.14.0",
    "motion": "12.38.0",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.1.2",
    "@storybook/addon-a11y": "10.3.6",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-mcp": "0.6.0",
    "@storybook/addon-vitest": "10.3.6",
    "@storybook/react-vite": "10.3.6",
    "@tailwindcss/postcss": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/coverage-v8": "4.1.6",
    "@vitest/ui": "4.1.6",
    "postcss": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "10.3.6",
    "storybook-addon-mock-date": "3.0.1",
    "tailwindcss": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-react": "2.2.0"
  },
  "peerDependencies": {
    "@types/react": ">=19.0.0",
    "@types/react-dom": ">=19.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "tailwindcss": ">=4.0.0",
    "typescript": ">=5.9.0"
  }
}
