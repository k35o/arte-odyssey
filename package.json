{
  "name": "arte-odyssey",
  "private": true,
  "description": "k8o's react ui library",
  "license": "MIT",
  "author": "k8o",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k35o/arte-odyssey.git"
  },
  "type": "module",
  "scripts": {
    "build": "vp run --filter './packages/*' --filter './apps/*' build",
    "test": "vp run -r test",
    "test:ui": "vp run -r test:ui",
    "test:coverage": "vp run -r test:coverage",
    "typecheck": "vp run -r typecheck",
    "check": "vp run -r check",
    "check:write": "vp run -r check:write",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@k8o/oxc-config": "0.1.2",
    "@oxlint/plugins": "1.63.0",
    "@types/node": "24.12.2",
    "agent-browser": "0.26.0",
    "cosmiconfig": "latest",
    "oxlint-tailwindcss": "0.7.0",
    "playwright": "1.59.1",
    "typescript": "6.0.3",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "packageManager": "pnpm@11.0.9"
}
