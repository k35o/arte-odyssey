{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "docs",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "docs", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "docs-prod",
      "runtimeExecutable": "node",
      "runtimeArgs": ["apps/docs/scripts/serve-static.mjs"],
      "port": 4173
    },
    {
      "name": "storybook",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@k8o/arte-odyssey", "storybook"],
      "port": 6006
    }
  ]
}
